{% extends 'admin/base.html.twig' %}
{% block title %}{{ showroom ? 'Editar Showroom' : 'Novo Showroom' }}{% endblock %}
{% block page_title %}{{ showroom ? 'Editar: ' ~ showroom.name : 'Novo Showroom' }}{% endblock %}
{% block page_subtitle %}<a href="{{ path('admin_showroom_index') }}" class="text-sm text-primary hover:underline">← Voltar para Showrooms</a>{% endblock %}

{% block admin_body %}
<div class="max-w-3xl">
<form method="POST" enctype="multipart/form-data">
    <div class="bg-white rounded-xl shadow-sm p-6 space-y-5">
        <div class="grid grid-cols-2 gap-5">
            <div class="col-span-2 form-group"><label class="form-label">Nome *</label><input type="text" name="name" value="{{ showroom ? showroom.name : '' }}" required class="form-input"></div>
            <div class="form-group"><label class="form-label">Cidade *</label><input type="text" name="city" value="{{ showroom ? showroom.city : '' }}" required class="form-input"></div>
            <div class="form-group"><label class="form-label">Estado (UF) *</label><input type="text" name="state" value="{{ showroom ? showroom.state : '' }}" required maxlength="2" class="form-input uppercase" placeholder="SP"></div>
            <div class="form-group"><label class="form-label">Bairro</label><input type="text" name="neighborhood" value="{{ showroom ? showroom.neighborhood : '' }}" class="form-input"></div>
            <div class="form-group"><label class="form-label">CEP</label><input type="text" name="zipcode" value="{{ showroom ? showroom.zipcode : '' }}" class="form-input" placeholder="00000-000"></div>
            <div class="form-group"><label class="form-label">Endereço</label><input type="text" name="address" value="{{ showroom ? showroom.address : '' }}" class="form-input"></div>
            <div class="form-group"><label class="form-label">Número</label><input type="text" name="number" value="{{ showroom ? showroom.number : '' }}" class="form-input"></div>
            <div class="form-group"><label class="form-label">Telefone</label><input type="text" name="phone" value="{{ showroom ? showroom.phone : '' }}" class="form-input" placeholder="(11) 3333-4444"></div>
            <div class="form-group"><label class="form-label">WhatsApp</label><input type="text" name="whatsapp" value="{{ showroom ? showroom.whatsapp : '' }}" class="form-input" placeholder="11999999999"></div>
            <div class="form-group"><label class="form-label">E-mail</label><input type="email" name="email" value="{{ showroom ? showroom.email : '' }}" class="form-input"></div>
            <div class="col-span-2 form-group"><label class="form-label">Horário de Atendimento</label><input type="text" name="openingHours" value="{{ showroom ? showroom.openingHours : '' }}" class="form-input" placeholder="Seg-Sex: 9h-18h | Sáb: 9h-13h"></div>
            <div class="col-span-2 form-group"><label class="form-label">Link Google Maps</label><input type="url" name="googleMapsUrl" value="{{ showroom ? showroom.googleMapsUrl : '' }}" class="form-input" placeholder="https://maps.google.com/..."></div>
            <div class="col-span-2 form-group"><label class="form-label">Foto Principal</label>
                {% if showroom and showroom.mainImage %}<img src="{{ asset('uploads/showroom/' ~ showroom.mainImage) }}" class="w-48 h-32 object-cover rounded-xl mb-3">{% endif %}
                <input type="file" name="mainImageFile" accept="image/*" class="form-input py-2 text-sm">
            </div>
            <div class="form-group"><label class="form-label">Ordem</label><input type="number" name="sortOrder" value="{{ showroom ? showroom.sortOrder : 0 }}" class="form-input"></div>
            <div class="flex items-center pt-6">
                <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" name="active" value="1" {% if not showroom or showroom.active %}checked{% endif %} class="w-4 h-4 text-primary rounded"><span class="text-sm font-medium">Ativo</span></label>
            </div>
        </div>
        <div class="flex gap-3 pt-2">
            <button type="submit" class="btn-primary">Salvar</button>
            <a href="{{ path('admin_showroom_index') }}" class="btn-secondary">Cancelar</a>
        </div>
    </div>
</form>
</div>
{% endblock %}
