{% extends 'admin/base.html.twig' %}
{% block title %}Showrooms{% endblock %}
{% block page_title %}Showrooms{% endblock %}
{% block page_subtitle %}<p class="text-sm text-gray-500">{{ showrooms|length }} showroom(s)</p>{% endblock %}

{% block admin_body %}
<div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <div class="p-5 border-b border-gray-100 flex justify-end">
        <a href="{{ path('admin_showroom_new') }}" class="btn-primary text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Novo Showroom
        </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 p-5">
        {% for s in showrooms %}
        <div class="border border-gray-100 rounded-xl overflow-hidden hover:shadow-md transition-shadow">
            {% if s.mainImage %}
                <img src="{{ asset('uploads/showroom/' ~ s.mainImage) }}" class="w-full h-40 object-cover" loading="lazy">
            {% else %}
                <div class="w-full h-40 bg-gradient-to-br from-primary/10 to-primary/5 flex items-center justify-center">
                    <svg class="w-10 h-10 text-primary/20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                </div>
            {% endif %}
            <div class="p-4">
                <div class="flex items-start justify-between gap-2 mb-2">
                    <h3 class="font-semibold text-gray-900">{{ s.name }}</h3>
                    {% if s.active %}<span class="badge-novo shrink-0">Ativo</span>{% else %}<span class="badge-promo shrink-0">Inativo</span>{% endif %}
                </div>
                <p class="text-sm text-primary font-medium">{{ s.city }}/{{ s.state }}</p>
                {% if s.address %}<p class="text-xs text-gray-500 mt-1">{{ s.address }}, {{ s.number }}</p>{% endif %}
                {% if s.phone %}<p class="text-xs text-gray-500">{{ s.phone }}</p>{% endif %}
                {% if s.openingHours %}<p class="text-xs text-gray-400 mt-1">{{ s.openingHours }}</p>{% endif %}
                <div class="mt-3 pt-3 border-t border-gray-100">
                    <a href="{{ path('admin_showroom_edit', {id: s.id}) }}" class="text-xs bg-primary/10 text-primary hover:bg-primary hover:text-white px-3 py-1.5 rounded-lg transition-colors font-medium">Editar</a>
                </div>
            </div>
        </div>
        {% else %}
        <div class="col-span-3 text-center py-16 text-gray-400">Nenhum showroom. <a href="{{ path('admin_showroom_new') }}" class="text-primary">Cadastrar</a></div>
        {% endfor %}
    </div>
</div>
{% endblock %}
