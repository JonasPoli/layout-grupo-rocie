{% extends 'admin/base.html.twig' %}
{% block title %}{{ representative ? 'Editar Representante' : 'Novo Representante' }}{% endblock %}
{% block page_title %}{{ representative ? 'Editar: ' ~ representative.name : 'Novo Representante' }}{% endblock %}
{% block page_subtitle %}<a href="{{ path('admin_representative_index') }}" class="text-sm text-primary hover:underline">← Voltar para Representantes</a>{% endblock %}

{% block admin_body %}
<div class="max-w-2xl">
<form method="POST">
    <div class="bg-white rounded-xl shadow-sm p-6 space-y-5">
        <div class="grid grid-cols-2 gap-5">
            <div class="col-span-2 form-group"><label class="form-label">Nome *</label><input type="text" name="name" value="{{ representative ? representative.name : '' }}" required class="form-input"></div>
            <div class="form-group"><label class="form-label">Empresa</label><input type="text" name="company" value="{{ representative ? representative.company : '' }}" class="form-input"></div>
            <div class="form-group"><label class="form-label">Estado (UF) *</label>
                <select name="state" required class="form-input">
                    {% set states = ['AC','AL','AM','AP','BA','CE','DF','ES','GO','MA','MG','MS','MT','PA','PB','PE','PI','PR','RJ','RN','RO','RR','RS','SC','SE','SP','TO'] %}
                    {% for uf in states %}
                        <option value="{{ uf }}" {% if representative and representative.state == uf %}selected{% endif %}>{{ uf }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="form-group"><label class="form-label">Cidade</label><input type="text" name="city" value="{{ representative ? representative.city : '' }}" class="form-input"></div>
            <div class="form-group"><label class="form-label">Região</label><input type="text" name="region" value="{{ representative ? representative.region : '' }}" class="form-input" placeholder="ex: Grande São Paulo"></div>
            <div class="form-group"><label class="form-label">Telefone</label><input type="text" name="phone" value="{{ representative ? representative.phone : '' }}" class="form-input"></div>
            <div class="form-group"><label class="form-label">WhatsApp</label><input type="text" name="whatsapp" value="{{ representative ? representative.whatsapp : '' }}" class="form-input" placeholder="11999999999"></div>
            <div class="col-span-2 form-group"><label class="form-label">E-mail</label><input type="email" name="email" value="{{ representative ? representative.email : '' }}" class="form-input"></div>
            <div class="col-span-2 form-group"><label class="form-label">Observações</label><textarea name="notes" rows="3" class="form-input">{{ representative ? representative.notes : '' }}</textarea></div>
            <div class="flex items-center">
                <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" name="active" value="1" {% if not representative or representative.active %}checked{% endif %} class="w-4 h-4 text-primary rounded"><span class="text-sm font-medium">Ativo</span></label>
            </div>
        </div>
        <div class="flex gap-3 pt-2">
            <button type="submit" class="btn-primary">Salvar</button>
            <a href="{{ path('admin_representative_index') }}" class="btn-secondary">Cancelar</a>
        </div>
    </div>
</form>
</div>
{% endblock %}
