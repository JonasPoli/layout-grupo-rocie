{% extends 'admin/base.html.twig' %}
{% block title %}Representantes{% endblock %}
{% block page_title %}Representantes{% endblock %}
{% block page_subtitle %}<p class="text-sm text-gray-500">{{ representatives|length }} representante(s)</p>{% endblock %}

{% block admin_body %}
<div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <div class="p-5 border-b border-gray-100 flex justify-end">
        <a href="{{ path('admin_representative_new') }}" class="btn-primary text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Novo Representante
        </a>
    </div>
    <table class="admin-table">
        <thead><tr><th>Nome</th><th>Estado</th><th>Cidade</th><th>Telefone</th><th>E-mail</th><th>Status</th><th class="w-24">Ações</th></tr></thead>
        <tbody>
        {% for rep in representatives %}
        <tr>
            <td><p class="font-medium text-gray-900">{{ rep.name }}</p>{% if rep.company %}<p class="text-xs text-gray-400">{{ rep.company }}</p>{% endif %}</td>
            <td><span class="text-xs font-bold text-primary bg-primary/10 px-2 py-1 rounded-lg">{{ rep.state }}</span></td>
            <td class="text-sm text-gray-600">{{ rep.city }}</td>
            <td class="text-xs text-gray-500">{{ rep.phone }}</td>
            <td class="text-xs text-gray-500">{{ rep.email }}</td>
            <td>{% if rep.active %}<span class="badge-novo">Ativo</span>{% else %}<span class="badge-promo">Inativo</span>{% endif %}</td>
            <td><a href="{{ path('admin_representative_edit', {id: rep.id}) }}" class="text-xs bg-primary/10 text-primary hover:bg-primary hover:text-white px-3 py-1.5 rounded-lg transition-colors font-medium">Editar</a></td>
        </tr>
        {% else %}
        <tr><td colspan="7" class="text-center py-12 text-gray-400">Nenhum representante. <a href="{{ path('admin_representative_new') }}" class="text-primary">Cadastrar</a></td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
