{% extends 'admin/base.html.twig' %}
{% block title %}{{ category ? 'Editar Categoria' : 'Nova Categoria' }}{% endblock %}
{% block page_title %}{{ category ? 'Editar: ' ~ category.name : 'Nova Categoria' }}{% endblock %}
{% block page_subtitle %}<a href="{{ path('admin_category_index') }}" class="text-sm text-primary hover:underline">← Voltar para Categorias</a>{% endblock %}

{% block admin_body %}
<div class="max-w-2xl">
<form method="POST" enctype="multipart/form-data">
    <div class="bg-white rounded-xl shadow-sm p-6 space-y-5">
        <div class="form-group"><label class="form-label">Nome *</label><input type="text" name="name" value="{{ category ? category.name : '' }}" required class="form-input"></div>
        <div class="form-group"><label class="form-label">Slug</label><input type="text" name="slug" value="{{ category ? category.slug : '' }}" class="form-input font-mono" placeholder="gerado-automaticamente"></div>
        <div class="form-group"><label class="form-label">Descrição Curta</label><textarea name="shortDescription" rows="3" class="form-input">{{ category ? category.shortDescription : '' }}</textarea></div>
        <div class="form-group"><label class="form-label">Imagem</label>
            {% if category and category.image %}<img src="{{ asset('uploads/category/' ~ category.image) }}" class="w-32 h-32 object-cover rounded-xl mb-3">{% endif %}
            <input type="file" name="imageFile" accept="image/*" class="form-input py-2 text-sm">
        </div>
        <div class="form-group"><label class="form-label">Ordem de Exibição</label><input type="number" name="sortOrder" value="{{ category ? category.sortOrder : 0 }}" class="form-input"></div>
        <div class="flex gap-6">
            <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" name="active" value="1" {% if not category or category.active %}checked{% endif %} class="w-4 h-4 text-primary rounded"><span class="text-sm font-medium">Ativa</span></label>
            <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" name="showOnHome" value="1" {% if category and category.showOnHome %}checked{% endif %} class="w-4 h-4 text-primary rounded"><span class="text-sm font-medium">Exibir na Home</span></label>
        </div>
        <div class="flex gap-3 pt-2">
            <button type="submit" class="btn-primary">Salvar</button>
            <a href="{{ path('admin_category_index') }}" class="btn-secondary">Cancelar</a>
        </div>
    </div>
</form>
</div>
{% endblock %}
