{% extends 'admin/base.html.twig' %}
{% block title %}Categorias{% endblock %}
{% block page_title %}Categorias{% endblock %}
{% block page_subtitle %}<p class="text-sm text-gray-500">{{ categories|length }} categoria(s)</p>{% endblock %}

{% block admin_body %}
<div class="bg-white rounded-xl shadow-sm overflow-hidden">
    <div class="p-5 border-b border-gray-100 flex justify-end">
        <a href="{{ path('admin_category_new') }}" class="btn-primary text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Nova Categoria
        </a>
    </div>
    <table class="admin-table">
        <thead><tr>
            <th class="w-14">Img</th><th>Nome</th><th>Slug</th><th>Ordem</th><th>Status</th><th class="w-24">Ações</th>
        </tr></thead>
        <tbody>
        {% for cat in categories %}
        <tr>
            <td>
                {% if cat.image %}<img src="{{ asset('uploads/category/' ~ cat.image) }}" class="w-10 h-10 object-cover rounded-lg">
                {% else %}<div class="w-10 h-10 bg-gray-100 rounded-lg"></div>{% endif %}
            </td>
            <td><p class="font-medium text-gray-900">{{ cat.name }}</p>{% if cat.shortDescription %}<p class="text-xs text-gray-400 line-clamp-1">{{ cat.shortDescription }}</p>{% endif %}</td>
            <td class="text-xs text-gray-500 font-mono">{{ cat.slug }}</td>
            <td class="text-xs text-gray-500">{{ cat.sortOrder }}</td>
            <td>
                {% if cat.active %}<span class="badge-novo">Ativa</span>{% else %}<span class="badge-promo">Inativa</span>{% endif %}
                {% if cat.showOnHome %}<span class="badge-destaque ml-1">Home</span>{% endif %}
            </td>
            <td>
                <a href="{{ path('admin_category_edit', {id: cat.id}) }}" class="text-xs bg-primary/10 text-primary hover:bg-primary hover:text-white px-3 py-1.5 rounded-lg transition-colors font-medium">Editar</a>
            </td>
        </tr>
        {% else %}
        <tr><td colspan="6" class="text-center py-12 text-gray-400">Nenhuma categoria. <a href="{{ path('admin_category_new') }}" class="text-primary">Cadastrar</a></td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
