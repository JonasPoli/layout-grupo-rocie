<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin{% endblock %} | Grupo Rocie</title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap">
    {% block stylesheets %}<link rel="stylesheet" href="{{ asset('styles/app.css') }}">{% endblock %}
</head>
<body class="bg-gray-100 font-body">

<div class="flex h-screen overflow-hidden" id="admin-layout">
    {# SIDEBAR #}
    <aside class="w-64 bg-primary flex flex-col shrink-0 overflow-y-auto" id="admin-sidebar">
        <div class="p-5 border-b border-white/10">
            <a href="{{ path('admin_dashboard') }}" class="flex items-center gap-3">
                <img src="{{ asset('images/logo.png') }}" alt="Grupo Rocie" class="h-8 w-auto brightness-0 invert" width="80" height="32">
                <div>
                    <div class="text-white font-semibold text-sm">Admin</div>
                    <div class="text-blue-200 text-xs">Grupo Rocie</div>
                </div>
            </a>
        </div>
        <nav class="flex-1 p-3 space-y-0.5" aria-label="Menu admin">
            <a href="{{ path('admin_dashboard') }}" class="admin-sidebar-link {% if app.request.attributes.get('_route') == 'admin_dashboard' %}active{% endif %}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                Dashboard
            </a>
            <div class="pt-3 pb-1 px-4 text-xs font-semibold text-blue-300 uppercase tracking-wider">Catálogo</div>
            <a href="{{ path('admin_product_index') }}" class="admin-sidebar-link {% if 'admin_product' in app.request.attributes.get('_route', '') %}active{% endif %}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                Produtos
            </a>
            <a href="{{ path('admin_category_index') }}" class="admin-sidebar-link {% if 'admin_category' in app.request.attributes.get('_route', '') %}active{% endif %}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
                Categorias
            </a>
            <a href="{{ path('admin_brand_index') }}" class="admin-sidebar-link {% if 'admin_brand' in app.request.attributes.get('_route', '') %}active{% endif %}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
                Marcas
            </a>
            <div class="pt-3 pb-1 px-4 text-xs font-semibold text-blue-300 uppercase tracking-wider">Estrutura</div>
            <a href="{{ path('admin_showroom_index') }}" class="admin-sidebar-link {% if 'admin_showroom' in app.request.attributes.get('_route', '') %}active{% endif %}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Showrooms
            </a>
            <a href="{{ path('admin_representative_index') }}" class="admin-sidebar-link {% if 'admin_representative' in app.request.attributes.get('_route', '') %}active{% endif %}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Representantes
            </a>
            <a href="{{ path('admin_banner_index') }}" class="admin-sidebar-link {% if 'admin_banner' in app.request.attributes.get('_route', '') %}active{% endif %}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                Banners
            </a>
            <div class="pt-3 pb-1 px-4 text-xs font-semibold text-blue-300 uppercase tracking-wider">Atendimento</div>
            <a href="{{ path('admin_message_index') }}" class="admin-sidebar-link {% if 'admin_message' in app.request.attributes.get('_route', '') %}active{% endif %}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                Mensagens
            </a>
        </nav>
        <div class="p-3 border-t border-white/10">
            <a href="{{ path('app_logout') }}" class="admin-sidebar-link text-red-300 hover:text-red-200 hover:bg-red-500/20">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                Sair
            </a>
        </div>
    </aside>

    {# MAIN CONTENT #}
    <div class="flex-1 flex flex-col overflow-hidden">
        <header class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between shrink-0">
            <div>
                <h1 class="text-lg font-semibold text-gray-900">{% block page_title %}Dashboard{% endblock %}</h1>
                {% block page_subtitle %}<p class="text-sm text-gray-500">Grupo Rocie Admin</p>{% endblock %}
            </div>
            <div class="flex items-center gap-3">
                <a href="{{ path('pub_home') }}" target="_blank" class="text-sm text-gray-500 hover:text-primary flex items-center gap-1.5 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    Ver site
                </a>
                <div class="w-8 h-8 bg-primary rounded-full flex items-center justify-center">
                    <span class="text-white text-xs font-bold">{{ app.user ? app.user.username|first|upper : 'A' }}</span>
                </div>
            </div>
        </header>
        <main class="flex-1 overflow-y-auto p-6">
            {% for type, messages in app.flashes %}
            {% for message in messages %}
            <div class="mb-4 p-4 rounded-xl {% if type == 'success' %}bg-green-50 text-green-800 border border-green-200{% elseif type == 'error' %}bg-red-50 text-red-800 border border-red-200{% else %}bg-blue-50 text-blue-800 border border-blue-200{% endif %} flex items-center gap-3">
                <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="{% if type == 'success' %}M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z{% else %}M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z{% endif %}"/></svg>
                {{ message }}
            </div>
            {% endfor %}
            {% endfor %}
            {% block admin_body %}{% endblock %}
        </main>
    </div>
</div>

{% block javascripts %}{{ importmap('app') }}{% endblock %}
</body>
</html>
