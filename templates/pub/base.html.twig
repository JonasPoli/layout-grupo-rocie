<!DOCTYPE html>
<html lang="pt-BR" class="" id="html-root">
<script>
// Prevent FOUC: apply saved theme before paint
(function(){
  var t = localStorage.getItem('theme');
  if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
    document.documentElement.classList.add('dark');
  }
})();
</script>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Grupo Rocie{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}Grupo Rocie — Produtos para sua loja e revenda. Variedade, marcas e atendimento para lojistas de todo o Brasil.{% endblock %}">
    <meta name="robots" content="index, follow">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap">
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}
    {% block head_extra %}{% endblock %}
</head>
<body style="background:var(--bg-body);color:var(--txt-body)" class="font-body antialiased">

{# HEADER #}
<header class="sticky top-0 z-50 shadow-md" id="site-header">

    {# ── Faixa 1: Topo escuro — SAC / Representante / Redes ── #}
    <div class="bg-gray-900 dark:bg-slate-950 text-gray-300">
        <div class="container mx-auto flex items-center justify-between py-2 px-4 xl:px-0">
            <div class="flex items-center divide-x divide-gray-700">
                <a href="{{ path('pub_sac') }}" class="text-xs hover:text-white transition-colors pr-4 flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 text-rocie-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                    SAC
                </a>
                <a href="{{ path('pub_representative') }}" class="text-xs hover:text-white transition-colors pl-4 flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 text-rocie-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    Torne-se um Representante
                </a>
            </div>
            <div class="flex items-center gap-2">
                {# Dark mode toggle #}
                <button id="theme-toggle" aria-label="Alternar modo escuro/claro" title="Alternar tema">
                    <svg class="icon-sun w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                    <svg class="icon-moon w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
                </button>
                <a href="https://instagram.com/gruporocie" target="_blank" rel="noopener" aria-label="Instagram"
                   class="w-7 h-7 flex items-center justify-center rounded-full bg-white/10 hover:bg-rocie-accent transition-all">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </a>
                <a href="https://facebook.com/gruporocie" target="_blank" rel="noopener" aria-label="Facebook"
                   class="w-7 h-7 flex items-center justify-center rounded-full bg-white/10 hover:bg-rocie-accent transition-all">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <a href="https://wa.me/5511999999999" target="_blank" rel="noopener" aria-label="WhatsApp"
                   class="w-7 h-7 flex items-center justify-center rounded-full bg-white/10 hover:bg-green-500 transition-all">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                </a>
            </div>
        </div>
    </div>

    {# ── Faixa 2: Branca — Logo + Busca + Área do Cliente ── #}
    <div style="background:var(--header-bg);border-bottom:1px solid var(--bg-border)">
        <div class="container mx-auto flex items-center gap-6 py-4 px-4 xl:px-0">
            <a href="{{ path('pub_home') }}" class="shrink-0 flex items-center gap-3" aria-label="Grupo Rocie">
                <img src="{{ asset('images/logo.png') }}" alt="Grupo Rocie" class="h-14 w-auto dark:brightness-0 dark:invert transition-all" width="56" height="56">
                <div class="hidden sm:block">
                    <div class="font-headline font-bold text-primary dark:text-blue-300 text-lg leading-tight">Grupo Rocie</div>
                    <div class="text-xs text-gray-400 dark:text-slate-500 tracking-wide">Atacado & Revenda</div>
                </div>
            </a>
            <form action="{{ path('pub_products') }}" method="GET" class="flex-1 flex" role="search">
                <div style="border:1px solid var(--bg-border)" class="flex w-full rounded-xl overflow-hidden focus-within:ring-2 focus-within:ring-primary/20 transition-all shadow-sm">
                    <select name="categoria" style="background:var(--bg-surface2);color:var(--txt-body);border-right:1px solid var(--bg-border)" class="hidden md:block text-sm px-4 py-0 focus:outline-none cursor-pointer" aria-label="Categoria">
                        <option value="">Todas as Categorias</option>
                        {% if categories is defined %}{% for cat in categories %}
                        <option value="{{ cat.slug }}">{{ cat.name }}</option>
                        {% endfor %}{% endif %}
                    </select>
                    <input type="search" name="q" placeholder="Buscar produtos, marcas, categorias…"
                           style="background:var(--bg-surface);color:var(--txt-heading)" class="flex-1 text-sm px-4 py-3 focus:outline-none" aria-label="Busca">
                    <button type="submit" class="bg-primary hover:bg-primary-dark text-white px-6 flex items-center gap-2 font-semibold text-sm transition-colors shrink-0">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/></svg>
                        <span class="hidden sm:inline">Buscar</span>
                    </button>
                </div>
            </form>
            <a href="#" class="hidden lg:flex items-center gap-2.5 shrink-0 group" aria-label="Área do cliente">
                <div class="w-10 h-10 rounded-full bg-gray-100 group-hover:bg-primary/10 flex items-center justify-center transition-colors">
                    <svg class="w-5 h-5 text-gray-500 group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                </div>
                <div>
                    <div class="text-xs text-gray-400">Olá, visitante</div>
                    <div class="text-sm font-semibold text-gray-800 group-hover:text-primary transition-colors leading-tight">Login</div>
                </div>
            </a>
            <button id="mobile-menu-btn" class="lg:hidden p-2 text-gray-600 hover:text-primary rounded-lg hover:bg-gray-100 transition-colors" aria-label="Abrir menu" aria-expanded="false">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
            </button>
        </div>
    </div>

    {# ── Faixa 3: Azul — Navegação ── #}
    <nav class="hidden lg:block bg-primary" aria-label="Menu principal">
        <div class="container mx-auto flex items-center gap-0 px-4 xl:px-0">
            {% set route = app.request.get('_route') %}
            <a href="{{ path('pub_home') }}" class="px-5 py-3.5 text-sm font-semibold transition-colors {% if route == 'pub_home' %}text-rocie-accent border-b-2 border-rocie-accent{% else %}text-white/80 hover:text-white hover:bg-white/10{% endif %}">Início</a>
            <a href="{{ path('pub_about') }}" class="px-5 py-3.5 text-sm font-semibold transition-colors {% if route == 'pub_about' %}text-rocie-accent border-b-2 border-rocie-accent{% else %}text-white/80 hover:text-white hover:bg-white/10{% endif %}">A Empresa</a>
            <a href="{{ path('pub_products') }}" class="px-5 py-3.5 text-sm font-semibold transition-colors {% if route starts with 'pub_product' %}text-rocie-accent border-b-2 border-rocie-accent{% else %}text-white/80 hover:text-white hover:bg-white/10{% endif %}">Produtos</a>
            <a href="{{ path('pub_showroom') }}" class="px-5 py-3.5 text-sm font-semibold transition-colors {% if route == 'pub_showroom' %}text-rocie-accent border-b-2 border-rocie-accent{% else %}text-white/80 hover:text-white hover:bg-white/10{% endif %}">Showroom</a>
            <a href="{{ path('pub_representative') }}" class="px-5 py-3.5 text-sm font-semibold transition-colors {% if route == 'pub_representative' %}text-rocie-accent border-b-2 border-rocie-accent{% else %}text-white/80 hover:text-white hover:bg-white/10{% endif %}">Representantes</a>
            <a href="{{ path('pub_contact') }}" class="px-5 py-3.5 text-sm font-semibold transition-colors {% if route == 'pub_contact' %}text-rocie-accent border-b-2 border-rocie-accent{% else %}text-white/80 hover:text-white hover:bg-white/10{% endif %}">Contato</a>
            <div class="flex-1"></div>
            <a href="https://wa.me/5511999999999" target="_blank" rel="noopener"
               class="flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white text-sm font-semibold px-5 py-2 my-2 rounded-lg transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                WhatsApp
            </a>
        </div>
    </nav>

    {# ── Mobile Nav ── #}
    <nav id="mobile-menu" class="hidden lg:hidden bg-white border-t border-gray-100 shadow-lg" aria-label="Menu mobile">
        <div class="container mx-auto px-4 py-3 flex flex-col gap-1">
            <a href="{{ path('pub_home') }}" class="px-3 py-2.5 text-sm font-medium text-gray-700 hover:text-primary hover:bg-blue-50 rounded-lg transition-colors">Início</a>
            <a href="{{ path('pub_about') }}" class="px-3 py-2.5 text-sm font-medium text-gray-700 hover:text-primary hover:bg-blue-50 rounded-lg transition-colors">A Empresa</a>
            <a href="{{ path('pub_products') }}" class="px-3 py-2.5 text-sm font-medium text-gray-700 hover:text-primary hover:bg-blue-50 rounded-lg transition-colors">Produtos</a>
            <a href="{{ path('pub_showroom') }}" class="px-3 py-2.5 text-sm font-medium text-gray-700 hover:text-primary hover:bg-blue-50 rounded-lg transition-colors">Showroom</a>
            <a href="{{ path('pub_representative') }}" class="px-3 py-2.5 text-sm font-medium text-gray-700 hover:text-primary hover:bg-blue-50 rounded-lg transition-colors">Representantes</a>
            <a href="{{ path('pub_contact') }}" class="px-3 py-2.5 text-sm font-medium text-gray-700 hover:text-primary hover:bg-blue-50 rounded-lg transition-colors">Contato</a>
            <a href="{{ path('pub_sac') }}" class="px-3 py-2.5 text-sm text-gray-500 hover:text-primary hover:bg-blue-50 rounded-lg transition-colors">SAC</a>
            <div class="pt-2">
                <a href="https://wa.me/5511999999999" target="_blank"
                   class="flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white text-sm font-semibold px-4 py-3 rounded-xl transition-colors justify-center">
                    WhatsApp
                </a>
            </div>
        </div>
    </nav>

</header>

{# CONTENT #}
<main>
    {% block body %}{% endblock %}
</main>

{# FOOTER #}
<footer class="bg-primary text-white">
    <div class="container mx-auto py-12">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
            {# Logo + Desc #}
            <div class="lg:col-span-1">
                <img src="{{ asset('images/logo.png') }}" alt="Grupo Rocie" class="h-12 w-auto brightness-0 invert mb-4" width="120" height="48">
                <p class="text-blue-100 text-sm leading-relaxed">
                    Produtos com qualidade e variedade para lojistas e revendedores de todo o Brasil.
                </p>
                <div class="flex items-center gap-3 mt-5">
                    <a href="https://instagram.com" target="_blank" aria-label="Instagram do Grupo Rocie" class="w-9 h-9 bg-white/10 rounded-lg flex items-center justify-center hover:bg-white/20 transition-colors">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                    </a>
                    <a href="https://facebook.com" target="_blank" aria-label="Facebook do Grupo Rocie" class="w-9 h-9 bg-white/10 rounded-lg flex items-center justify-center hover:bg-white/20 transition-colors">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    </a>
                </div>
            </div>
            {# Menu Rápido #}
            <div>
                <h4 class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">Menu</h4>
                <ul class="space-y-2">
                    <li><a href="{{ path('pub_home') }}" class="footer-link">Início</a></li>
                    <li><a href="{{ path('pub_about') }}" class="footer-link">A Empresa</a></li>
                    <li><a href="{{ path('pub_products') }}" class="footer-link">Produtos</a></li>
                    <li><a href="{{ path('pub_showroom') }}" class="footer-link">Showroom</a></li>
                    <li><a href="{{ path('pub_contact') }}" class="footer-link">Contato</a></li>
                    <li><a href="{{ path('pub_sac') }}" class="footer-link">SAC</a></li>
                    <li><a href="{{ path('pub_representative') }}" class="footer-link">Torne-se Representante</a></li>
                </ul>
            </div>
            {# Contato #}
            <div>
                <h4 class="font-semibold text-white mb-4 text-sm uppercase tracking-wider">Contato</h4>
